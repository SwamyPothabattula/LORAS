@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

@model Customer

<h1 class="display-6 mb-4">My Info</h1>

<table class="table table-hover border">
    <tbody>
        <tr>
            <th class="bg-light" style="width: 30%;">First Name</th>
            <td>@Model.FirstName</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="FirstName" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">Last Name</th>
            <td>@Model.LastName</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="LastName" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">Email</th>
            <td>@Model.Email</td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">DateOfBirth</th>
            <td>@Model.DateOfBirth.ToShortDateString()</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="DateOfBirth" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">AadharNumber</th>
            <td>@Model.AadharNumber</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="AadharNumber" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">PanNumber</th>
            <td>@Model.PanNumber</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="PanNumber" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">PhoneNumber</th>
            <td>@Model.PhoneNumber</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="PhoneNumber" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">GenderType</th>
            <td>@Model.GenderType</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="GenderType" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">MaritalStatus</th>
            <td>@Model.MaritalStatus</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="MaritalStatus" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">EmployementType</th>
            <td>@Model.EmployementType</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="EmployementType" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">Address</th>
            <td>@Model.Address</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="Address" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
        <tr>
            <th class="bg-light" style="width: 30%;">AnnualIncome</th>
            <td>@Model.AnnualIncome</td>
            <td class="text-end">
                <a asp-action="Update" asp-controller="Customer" asp-route-id="@Model.CustomerId" asp-route-field="AnnualIncome" class="text-primary text-decoration-none">
                    <i class="bi bi-pencil-square"></i>
                </a>
            </td>
        </tr>
    </tbody>
</table>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">