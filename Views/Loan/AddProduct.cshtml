
@{
    Layout = "~/Views/Shared/_LoanLayout.cshtml";
}
@model LoanProduct
<form asp-action="AddProduct" method="post">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-4">
                
                <h3 class="text-center mb-4">Add Product</h3>

                <div class="mb-3">
                    <label asp-for="ProductName" class="form-label">Product Name</label>
                    <input type="text" asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="LoanType" class="form-label">LoanType</label>
                    <select asp-items="Html.GetEnumSelectList<LoanType>()" asp-for="LoanType" class="form-control"></select>
                    <span asp-validation-for="LoanType"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="InterestRate" class="form-label">InterestRate</label>
                    <input type="text" asp-for="InterestRate" class="form-control" />
                    <span asp-validation-for="InterestRate"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MinAmount" class="form-label">MinAmount</label>
                    <input type="text" asp-for="MinAmount" class="form-control" />
                    <span asp-validation-for="MinAmount"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MaxAmount" class="form-label">MaxAmount</label>
                    <input type="text" asp-for="MaxAmount" class="form-control" />
                    <span asp-validation-for="MaxAmount"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MinTenure" class="form-label">MinTenure</label>
                    <input type="text" asp-for="MinTenure" class="form-control" />
                    <span asp-validation-for="MinTenure"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MaxTenure" class="form-label">MaxTenure</label>
                    <input type="text" asp-for="MaxTenure" class="form-control" />
                    <span asp-validation-for="MaxTenure"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ProcessingFee" class="form-label">ProcessingFee</label>
                    <input type="text" asp-for="ProcessingFee" class="form-control" />
                    <span asp-validation-for="ProcessingFee"></span>
                </div>

              <button type="submit" class="btn btn-primary">Submit</button>
        </div>
        </div>
    </div>
</form>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>